---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="cv-container">
			<!-- 1. 左側のナビゲーション -->
			<aside class="sidebar">
				<nav>
					<ul>
						<li><a href="#contact">Contact Information</a></li>
						<li><a href="#summary">Professional Summary</a></li>
						<li><a href="#experience">Experience</a></li>
						<li><a href="#education">Education</a></li>
						<li><a href="#skills">Skills</a></li>
					</ul>
				</nav>
			</aside>

			<!-- 2. 右側のメインコンテンツ -->
			<div class="content">
				<header class="page-header">
					<h1>CV</h1>
					<p>Ayumu Nomura — curriculum vitae.</p>
				</header>

				<!-- Contact Section -->
				<section id="contact" class="cv-card">
					<h2>Contact Information</h2>
					<div class="info-grid">
						<div class="label">Name</div>
						<div class="value">Ayumu Nomura (野村歩)</div>
						<div class="label">Professional Title</div>
						<div class="value">Research Engineer</div>
						<div class="label">Email</div>
						<div class="value">example@example.com</div>
					</div>
				</section>

				<!-- Summary Section -->
				<section id="summary" class="cv-card">
					<h2>Professional Summary</h2>
					<p>
						Engineer and researcher at Nissan Motor Corporation (R&D Division). 
						Currently focused on the development of connected car services (CCS).
					</p>
				</section>

				<!-- Experience Section -->
				<section id="experience" class="cv-card">
					<h2>Experience</h2>
					<div class="experience-item">
						<div class="time-location">
							<span class="badge">2024 - PRESENT</span>
							<span class="location">📍 Yokohama, Japan</span>
						</div>
						<div class="details">
							<h3>Research Engineer, R&D Division</h3>
							<p class="company">Nissan Motor Corporation</p>
						</div>
					</div>
				</section>
			</div>
		</main>
		<Footer />

		<style>
			/* 全体のレイアウト設定 */
			.cv-container {
				display: grid;
				grid-template-columns: 280px 1fr; /* 左280px、右残り */
				gap: 40px;
				max-width: 1100px;
				margin: 40px auto;
				padding: 0 20px;
				align-items: start;
			}

			/* サイドバーの設定 */
			.sidebar {
				position: sticky;
				top: 100px; /* Headerの下に固定 */
			}
			.sidebar ul {
				list-style: none;
				padding: 0;
			}
			.sidebar li {
				margin-bottom: 15px;
			}
			.sidebar a {
				text-decoration: none;
				color: #333;
				font-weight: 600;
				font-size: 0.95rem;
			}
			.sidebar a:hover {
				color: #d111d1;
			}

			/* カードのデザイン */
			.cv-card {
				background: white;
				border: 1px solid #e5e7eb;
				border-radius: 12px;
				padding: 32px;
				margin-bottom: 24px;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
			}
			.cv-card h2 {
				margin-top: 0;
				font-size: 1.5rem;
				border-bottom: 1px solid #f3f4f6;
				padding-bottom: 16px;
				margin-bottom: 20px;
			}

			/* 表形式のレイアウト */
			.info-grid {
				display: grid;
				grid-template-columns: 180px 1fr;
				gap: 12px;
			}
			.label { font-weight: bold; color: #4b5563; }

			/* 経歴のバッジ設定 */
			.badge {
				background: #d111d1; /* 画像のような鮮やかなパープル */
				color: white;
				padding: 4px 12px;
				border-radius: 6px;
				font-size: 0.75rem;
				font-weight: bold;
				display: inline-block;
				margin-bottom: 8px;
			}
			.experience-item {
				display: grid;
				grid-template-columns: 180px 1fr;
				gap: 20px;
			}
			.experience-item h3 { margin: 0; font-size: 1.2rem; }
			.company { color: #6b7280; margin: 4px 0; }

			/* レスポンシブ対応（スマホで見るときは1列にする） */
			@media (max-width: 768px) {
				.cv-container {
					grid-template-columns: 1fr;
				}
				.sidebar {
					position: relative;
					top: 0;
				}
			}
		</style>
	</body>
</html>